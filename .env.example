# steelg8 环境变量样板
# 用法：cp .env.example .env，填好对应的 API Key；启动前 `source .env` 或用 launchd/SwiftUI 注入。
# 注意：.env 不入库，keep secrets out of git。

# ────────────── 四家 provider API Key ──────────────
# 只填你真实有的就行，没填的 provider 会自动识别为 "not ready"，不影响其他 provider。

# 月之暗面 Kimi（含 Coding Plan 调 API）
KIMI_API_KEY=

# DeepSeek（便宜批处理主力）
DEEPSEEK_API_KEY=

# 阿里百炼 Qwen（用 OpenAI 兼容模式）
QWEN_API_KEY=

# OpenRouter（多模型聚合，做 failover 和国际模型接入）
OPENROUTER_API_KEY=

# ────────────── 路由 / 默认行为 ──────────────
# 可选：override 默认模型；不设则用 providers.json 里的 default_model
# STEELG8_DEFAULT_MODEL=deepseek-chat

# 可选：自定义 providers 配置文件路径（默认是 ~/.steelg8/providers.json）
# STEELG8_PROVIDERS_PATH=/absolute/path/to/providers.json

# 可选：自定义 soul.md 位置（默认是 ~/.steelg8/soul.md）
# STEELG8_SOUL_PATH=/absolute/path/to/soul.md

# 可选：端口；Swift 端默认连 8765
# STEELG8_PORT=8765

# ────────────── 向后兼容（单 provider 快速测试用）──────────────
# 如果只想临时试一家，不想写 providers.json，可以直接走这三个变量。
# providers.json 存在时，这些变量被忽略。
# STEELG8_OPENAI_BASE_URL=https://api.deepseek.com
# STEELG8_OPENAI_API_KEY=sk-...
# STEELG8_OPENAI_MODEL=deepseek-chat
